# NavBuddy Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# ── Required ─────────────────────────────────────────────────────

# Google Maps API key — for route generation + Street View imagery
# Enable: Directions API, Street View Static API, Geocoding API
GOOGLE_MAPS_API_KEY=

# OpenRouter API key — for VLM inference (Gemini, GPT, Grok, Claude, etc.)
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Optional: HuggingFace ────────────────────────────────────────

# HuggingFace token — needed for gated models (Gemma, Llama, etc.)
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Optional: Upstash (inference caching + embeddings) ──────────

# Upstash Redis — caches LLM judge results to avoid re-scoring
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash Vector — stores instruction embeddings for similarity search
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# ── Optional: Self-hosted inference ─────────────────────────────

# Override inference base URL (e.g. point at self-hosted vLLM server)
# NAVBUDDY_INFERENCE_BASE_URL=http://localhost:8000/v1
